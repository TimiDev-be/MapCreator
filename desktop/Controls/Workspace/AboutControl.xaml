<UserControl x:Class="desktop.Controls.Workspace.AboutControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:desktop.Controls.Workspace"
             xmlns:sys="clr-namespace:System.Reflection;assembly=mscorlib"
             mc:Ignorable="d"
             MinHeight="100"
             MinWidth="600">
    <Grid>
        <Border Padding="16 32"
            Background="White">

            <StackPanel Orientation="Vertical">

                <StackPanel Orientation="Horizontal"
                        Margin="0 0 0 8">
                    <Image Source="/Assets/About.png"
                        Margin="0 0 8 0"
                        VerticalAlignment="Center"
                        Width="24"
                        Height="24"/>
                    <TextBlock Text="About"
                            Foreground="{StaticResource Black}"
                            FontSize="20"
                            VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock x:Name="AppNameTextBlock"
                        Foreground="{StaticResource Black}"
                        FontSize="16"
                        Margin="0 0 0 8"/>

                <TextBlock x:Name="VersionTextBlock"
                        Foreground="{StaticResource Black}"
                        FontSize="16"
                        Margin="0 0 0 8"/>

                <TextBlock x:Name="GithubRepoLinkTextBLock"
                        Text="https://github.com/TimiDev-be/MapCreator"
                        Foreground="{StaticResource Black}"
                        FontSize="16"
                        Margin="0 0 0 8"/>

            </StackPanel>
            
        </Border>
    </Grid>
</UserControl>
