<UserControl x:Class="desktop.Controls.Workspace.LogsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:desktop.Controls.Workspace"
             mc:Ignorable="d" 
             MinHeight="100"
             MinWidth="600">
    <Grid>

        <Border Padding="16 32"
            Background="White">

            <StackPanel Orientation="Vertical"
                    Margin="0 0 0 8">

                <StackPanel Orientation="Horizontal"
                        Margin="0 0 0 8">
                    <Image Source="/Assets/Document.png"
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center"
                        Margin="0 0 8 0"/>
                    <TextBlock Text="Logs"
                            Foreground="{StaticResource Black}"
                            FontSize="20"
                            VerticalAlignment="Center"/>
                </StackPanel>
                <!--Errors are kept for 14 days, then removed automatically.-->
                <TextBlock Text="in working progress..."
                        Foreground="{StaticResource Black}"
                        FontSize="16"
                        Margin="0 0 0 8"/>

            </StackPanel>
            
        </Border>

    </Grid>
</UserControl>
