<UserControl x:Class="desktop.Controls.Workspace.WorkspaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:desktop.Controls.Workspace"
             mc:Ignorable="d"
             Background="White"
             MinWidth="1100"
             MinHeight="600"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    <Grid>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <local:NavigationControl x:Name="Navigation"
                                Grid.Column="0"
                                Grid.Row="0"/>

        <ScrollViewer Grid.Column="1"
                    Grid.Row="0"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    VerticalScrollBarVisibility="Auto"
                    Padding="8 0">
            <StackPanel x:Name="ContentContainer"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <local:StylesControl Margin="0 0 0 8"/>
                
                <Border BorderBrush="{StaticResource Black}"
                    BorderThickness="0 0 0 1"
                    Margin="0 0 0 16"/>

            </StackPanel>
        </ScrollViewer>
        
    </Grid>
</UserControl>
