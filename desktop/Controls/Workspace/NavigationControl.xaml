<UserControl x:Class="desktop.Controls.Workspace.NavigationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:desktop.Controls.Workspace"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             MinWidth="200"
             MaxWidth="300"
             MinHeight="600">
    <Grid>

        <Border x:Name="NavigationContainer"
            Padding="16"
            Background="#F8F8F8"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            BorderThickness="0 0 1 0"
            BorderBrush="{StaticResource BlueLight}">
            <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">

                <TextBlock Text="WORKSPACE"
                        FontSize="16"
                        FontWeight="Normal"
                        Foreground="{StaticResource Black}"
                        Margin="0 0 0 16"/>

                <RadioButton x:Name="StylesNavButton"
                            Tag="styles"
                            Style="{StaticResource NavButtonStyle}"
                            GroupName="Nav"
                            Click="NavigationButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Paint.png"
                            Width="24"
                            Height="24"/>
                        <TextBlock Text="Styles"
                                Margin="8 0 0 0"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="LogsNavButton"
                            Tag="logs"
                            Style="{StaticResource NavButtonStyle}"
                            GroupName="Nav"
                            Click="NavigationButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Document.png"
                            Width="24"
                            Height="24"/>
                        <TextBlock Text="Logs"
                                Margin="8 0 0 0"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="AboutNavButton"
                            Tag="about"
                            Style="{StaticResource NavButtonStyle}"
                            GroupName="Nav"
                            Click="NavigationButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/About.png"
                            Width="24"
                            Height="24"/>
                        <TextBlock Text="About"
                                Margin="8 0 0 0"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>

                <Line X1="0" 
                    Y1="0" 
                    X2="300" 
                    Y2="0" 
                    Stroke="{StaticResource BlueDarker}" 
                    StrokeThickness="2"
                    Margin="0 0 0 16"/>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
