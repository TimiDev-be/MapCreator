<UserControl x:Class="desktop.Controls.ChangeUrlControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:desktop.Controls"
             mc:Ignorable="d"
             Width="Auto"
             Height="Auto">
    <Grid>

        <Border x:Name="ChangeUrlContainer"
            Background="White"
            Padding="16"
            CornerRadius="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect Color="{StaticResource CBlack}"
                                Opacity="0.1"
                                BlurRadius="10"
                                ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="Change existing style" 
                            FontSize="20"
                            FontWeight="Medium"
                            Foreground="{StaticResource Black}"
                            Margin="0, 0, 0, 8"/>

                    <TextBlock Text="Name:" 
                            FontSize="16"
                            FontWeight="Medium"
                            Foreground="{StaticResource Black}"
                            Margin="0, 0, 0, 8"/>

                    <TextBox x:Name="NameTextBox"    
                            Style="{StaticResource TextBoxInputStyle}"
                            TextChanged="NameTextBox_TextChanged"/>

                    <Border x:Name="NameTextBoxErrorContainer"
                        Margin="0 8"
                        Visibility="Collapsed">
                        <TextBlock x:Name="NameTextBoxErrorMessage"
                                TextWrapping="Wrap"
                                FontSize="14" 
                                Foreground="{StaticResource BlueNormal}"/>
                    </Border>
                    <TextBlock Text="Map style url:" 
                            FontSize="16"
                            FontWeight="Medium"
                            Foreground="{StaticResource Black}"
                            Margin="0, 0, 0, 8"/>

                    <TextBox x:Name="UrlTextBox"    
                            Style="{StaticResource TextBoxInputStyle}"
                            TextChanged="UrlTextBox_TextChanged"/>

                    <Border x:Name="UrlTextBoxErrorContainer"
                        Margin="0 8"
                        Visibility="Collapsed">
                        <TextBlock x:Name="UrlTextBoxErrorMessage"
                                TextWrapping="Wrap"
                                FontSize="14" 
                                Foreground="{StaticResource BlueNormal}"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="0 8 0 0">
                        <Button x:Name="CloseButton"
                            Style="{StaticResource CloseButtonStyle}"
                            Content="Close"
                            Click="CloseButton_Click"/>
                        <Button x:Name="SaveUrlButton"
                            Style="{StaticResource SaveButtonStyle}"
                            Content="Save"
                            Margin="8 0 0 0"
                            Click="SaveStyleButton_Click"/>
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
