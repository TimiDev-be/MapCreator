<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--Colors-->
    
    <Color x:Key="CBlueLight">#e6f0f8</Color>
    <Color x:Key="CBlueLightHover">#dae8f5</Color>
    <Color x:Key="CBlueLightActive">#b2cfea</Color>

    <Color x:Key="CBlueNormal">#0864ba</Color>
    <Color x:Key="CBlueNormalHover">#075aa7</Color>
    <Color x:Key="CBlueNormalActive">#065095</Color>

    <Color x:Key="CBlueDark">#064b8c</Color>
    <Color x:Key="CBlueDarkHover">#053c70</Color>
    <Color x:Key="CBlueDarkActive">#042d54</Color>
    <Color x:Key="CBlueDarker">#032341</Color>

    <Color x:Key="CBlack">#2E2C2A</Color>
    
    <!--Colors brush-->

    <SolidColorBrush x:Key="BlueLight" Color="{StaticResource CBlueLight}"/>
    <SolidColorBrush x:Key="BlueLightHover" Color="{StaticResource CBlueLightHover}"/>
    <SolidColorBrush x:Key="BlueLightActive" Color="{StaticResource CBlueLightActive}"/>
    
    <SolidColorBrush x:Key="BlueNormal" Color="{StaticResource CBlueNormal}"/>
    <SolidColorBrush x:Key="BlueNormalHover" Color="{StaticResource CBlueNormalHover}"/>
    <SolidColorBrush x:Key="BlueNormalActive" Color="{StaticResource CBlueNormalActive}"/>
    
    <SolidColorBrush x:Key="BlueDark" Color="{StaticResource CBlueDark}"/>
    <SolidColorBrush x:Key="BlueDarkHover" Color="{StaticResource CBlueDarkHover}"/>
    <SolidColorBrush x:Key="BlueDarkActive" Color="{StaticResource CBlueDarkActive}"/>
    <SolidColorBrush x:Key="BlueDarker" Color="{StaticResource CBlueDarker}"/>
    
    <SolidColorBrush x:Key="Black" Color="{StaticResource CBlack}"/>

</ResourceDictionary>